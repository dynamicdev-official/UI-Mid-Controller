# ─── Webhook Configuration ────────────────────────────────────────────────────
# ใส่ URL ของ Webhook ที่ต้องการเรียกจาก UI
# สามารถ override ทั้งหมดนี้ใน docker-compose.yml ได้

# Webhook URL หลัก (ใส่ URL เต็มของแต่ละ Endpoint ที่ต้องการ trigger)
WEBHOOK_URL=https://n8n.yourdomain.com/webhook/your-endpoint

# Webhook สำหรับ AI Chat
CHAT_WEBHOOK=https://n8n.yourdomain.com/webhook/chat

# Webhook สำหรับตรวจสอบสถานะระบบ
MONITOR_WEBHOOK=https://n8n.yourdomain.com/webhook/status-check

# ─── API Keys (ถ้ามี) ────────────────────────────────────────────────────────
API_KEY=your_secure_api_key_here
